# GitHub App
GITHUB_APP_ID=                          # integer app ID from GitHub App settings
GITHUB_PRIVATE_KEY=                     # base64-encoded PEM string, or absolute path to .pem file
GITHUB_WEBHOOK_SECRET=                  # HMAC secret configured in GitHub App settings
GITHUB_INSTALLATION_ID=                 # installation ID — find at github.com/settings/installations or via API
GITHUB_REPO_OWNER= "RAGNAROS-HS"                    # GitHub org or user that owns the target repo
GITHUB_REPO_NAME= "Weles"                      # target repo name (without owner prefix)
BOT_GITHUB_LOGIN="glima[bot]"           # the GitHub login shown as the PR/issue author

# LLM
LLM_PROVIDER=anthropic                  # "anthropic" | "openai"
LLM_API_KEY=                            # Anthropic or OpenAI API key
LLM_MODEL_SCOUT=claude-sonnet-4-6       # broad scan — sonnet is cost-effective
LLM_MODEL_FIXER=claude-sonnet-4-6       # code edits — sonnet handles most fixes well
LLM_MODEL_REVIEWER=claude-opus-4-6     # adversarial review — opus for highest scrutiny
LLM_MODEL_DOCUMENTER=claude-sonnet-4-6  # doc updates — sonnet is sufficient

# Behaviour
SCOUT_CRON="0 2 * * *"                 # nightly at 02:00 UTC
MAX_FIX_ITERATIONS=3                    # review loops before halting and escalating to human
QODO_BOT_USERNAME="qodo-merge[bot]"    # GitHub login of the Qodo PR review bot
LLM_TOKEN_BUDGET_SCOUT=80000           # approximate token budget for codebase context sent to Scout
PORT=3000                               # HTTP port for the webhook server
